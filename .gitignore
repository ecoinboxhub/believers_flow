# ===========================
# BelieversFlow .gitignore
# ===========================

# ---------------------------
# Dependencies
# ---------------------------
node_modules/
.pnp
.pnp.js

# ---------------------------
# Build Output
# ---------------------------
dist/
dist-ssr/
build/
*.local

# ---------------------------
# Environment & Secrets
# ---------------------------
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
backend/.env
backend/.env.local
backend/.env.*.local

# ---------------------------
# Signing & Certificates
# ---------------------------
*.jks
*.keystore
*.p12
*.pem
*.key
mobile/app/signing.properties

# API keys & credentials
client_secret*.json
credentials*.json
service-account*.json
*-service-account*.json

# ---------------------------
# Python
# ---------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
env/
ENV/
.python-version
*.egg-info/
*.egg
.eggs/
sdist/
wheels/

# Pytest / Coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Mypy / Ruff / Type checkers
.mypy_cache/
.ruff_cache/
.pytype/

# Alembic
backend/alembic/versions/*.pyc

# ---------------------------
# Node.js
# ---------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ---------------------------
# Editor / IDE
# ---------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*‾
.project
.classpath
.settings/

# ---------------------------
# OS-generated
# ---------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
.Spotlight-V100
.Trashes
._*

# ---------------------------
# Mobile / Android / Gradle
# ---------------------------
mobile/.gradle/
mobile/build/
mobile/app/build/
mobile/capacitor-cordova-android-plugins/build/
mobile/local.properties
*.apk
*.aab
*.ap_
mobile/.idea/
mobile/*.iml
mobile/**/*.iml
mobile/gradle/wrapper/gradle-wrapper.jar

# ---------------------------
# iOS
# ---------------------------
ios/Pods/
ios/build/
ios/**/*.xcworkspace/xcuserdata/
ios/**/*.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
ios/**/*.xcodeproj/xcuserdata/
ios/**/*.pbxuser
ios/**/*.mode1v3
ios/**/*.mode2v3
ios/**/*.perspectivev3

# ---------------------------
# Testing & Coverage
# ---------------------------
test-results/
frontend/test-results/
frontend/playwright-report/
playwright-report/
playwright/.cache/
blob-report/
*.snap.bak
screenshots/

# ---------------------------
# Logs & Debug
# ---------------------------
logs/
*.pid
*.seed
*.pid.lock
debug.log
pm2-debug.log

# ---------------------------
# Temporary & Backup
# ---------------------------
*.tmp
*.temp
*.bak
*.backup
*.orig
*.OLD
*‾
‾$*
‾$*.docx
‾$*.pptx
‾$*.xlsx

# ---------------------------
# Deployment
# ---------------------------
.vercel/
.vercel/*.local
backend/.vercel/

# ---------------------------
# Docker
# ---------------------------
docker-compose.override.yml

# ---------------------------
# Documentation build artifacts
# ---------------------------
docs/site/
docs/_build/

# ---------------------------
# Generated test output
# ---------------------------
test_results.json
security_scalability_results.json

# ---------------------------
# Large binary / presentation files
# ---------------------------
*.docx
*.pptx
*.pdf
!presentations/**
