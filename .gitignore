# ===========================
# BelieversFlow .gitignore
# ===========================

# ---------------------------
# Dependencies
# ---------------------------
node_modules/
.pnp
.pnp.js

# ---------------------------
# Build Output
# ---------------------------
dist/
dist-ssr/
build/
*.local

# ---------------------------
# Environment & Secrets
# ---------------------------
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
backend/.env
backend/.env.local
backend/.env.*.local

# Android signing secrets
*.jks
*.keystore
*.p12
*.pem
*.key
android/app/signing.properties

# API keys & credentials
client_secret*.json
credentials*.json
service-account*.json
*-service-account*.json

# ---------------------------
# Python
# ---------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
.venv/
env/
ENV/
.python-version

# Distribution / packaging
*.egg-info/
*.egg
.eggs/
sdist/
wheels/

# Pytest / Coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Mypy / Ruff / Type checkers
.mypy_cache/
.ruff_cache/
.pytype/

# Alembic
backend/alembic/versions/*.pyc

# ---------------------------
# Node.js
# ---------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ---------------------------
# Editor / IDE
# ---------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---------------------------
# OS-generated
# ---------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
.Spotlight-V100
.Trashes
._*

# ---------------------------
# Android / Gradle
# ---------------------------
android/.gradle/
android/build/
android/app/build/
android/capacitor-cordova-android-plugins/build/
android/local.properties
*.apk
*.aab
*.ap_

# Android Studio
android/.idea/
android/*.iml
android/**/*.iml
android/gradle/wrapper/gradle-wrapper.jar

# ---------------------------
# iOS
# ---------------------------
ios/Pods/
ios/build/
ios/**/*.xcworkspace/xcuserdata/
ios/**/*.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
ios/**/*.xcodeproj/xcuserdata/
ios/**/*.pbxuser
ios/**/*.mode1v3
ios/**/*.mode2v3
ios/**/*.perspectivev3

# ---------------------------
# Capacitor
# ---------------------------
node_modules/@capacitor/

# ---------------------------
# Testing & Coverage
# ---------------------------
test-results/
playwright-report/
playwright/.cache/
blob-report/
*.snap.bak
screenshots/

# ---------------------------
# Logs & Debug
# ---------------------------
logs/
*.pid
*.seed
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
debug.log
pm2-debug.log

# ---------------------------
# Temporary & Backup
# ---------------------------
*.tmp
*.temp
*.bak
*.backup
*.orig
*.OLD
*~
~$*

# ---------------------------
# Deployment
# ---------------------------
.vercel/
.vercel/*.local

# ---------------------------
# Docker
# ---------------------------
docker-compose.override.yml

# ---------------------------
# Documentation build artifacts
# ---------------------------
docs/site/
docs/_build/

# ---------------------------
# Pitch & Investor Materials (local only)
# ---------------------------
pitch/*.docx
pitch/*.pptx
pitch/*.pdf
pitch/~$*

# Presentation temp files
~$*.docx
~$*.pptx
~$*.xlsx

# ---------------------------
# Archive
# ---------------------------
backup_old/

# ---------------------------
# Capacitor (root level)
# ---------------------------
capacitor-cordova-android-plugins/
