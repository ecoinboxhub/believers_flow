# EditorConfig — https://editorconfig.org
# BelieversFlow coding style defaults

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{py,pyi}]
indent_size = 4

[*.{gradle,groovy}]
indent_size = 4

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.java]
indent_size = 4

[*.{xml,html}]
indent_size = 2

[*.css]
indent_size = 2

[*.{js,jsx,mjs,cjs}]
indent_size = 2

[*.ts,*.tsx]
indent_size = 2

[Dockerfile]
indent_size = 4

[*.sh]
indent_size = 2

[*.bat]
indent_style = tab
