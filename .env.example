# GROQ API Key for AI Believer Tips feature
# Get your free key at: https://console.groq.com/keys
# Then rename this file to .env and add your key
VITE_GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# Backend API URL (leave empty to use direct GROQ calls from browser)
# Set to your Vercel deployment URL when backend is deployed
# VITE_API_URL=https://your-app.vercel.app
